{
  "name": "yokko",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "build": "npm run typecheck && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "avito:auth": "node scripts/avito/save-auth-state.mjs",
    "avito:auth:seller": "AVITO_AUTH_LABEL=seller AVITO_AUTH_STATE=.auth/avito-seller.json node scripts/avito/save-auth-state.mjs",
    "avito:auth:buyer": "AVITO_AUTH_LABEL=buyer AVITO_AUTH_STATE=.auth/avito-buyer.json node scripts/avito/save-auth-state.mjs",
    "avito:audit": "node scripts/avito/run-audit.mjs",
    "avito:audit:seller": "AVITO_ROLE=seller AVITO_AUTH_STATE=.auth/avito-seller.json AVITO_OUTPUT_DIR=reports/avito-audit/seller node scripts/avito/run-audit.mjs",
    "avito:audit:buyer": "AVITO_ROLE=buyer AVITO_AUTH_STATE=.auth/avito-buyer.json AVITO_OUTPUT_DIR=reports/avito-audit/buyer node scripts/avito/run-audit.mjs",
    "avito:audit:roles": "node scripts/avito/run-role-audits.mjs"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^9.39.1",
    "@storybook/addon-a11y": "^10.2.13",
    "@storybook/addon-docs": "^10.2.13",
    "@storybook/addon-onboarding": "^10.2.13",
    "@storybook/addon-vitest": "^10.2.13",
    "@storybook/react-vite": "^10.2.13",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.2.13",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "prop-types": "^15.8.1",
    "storybook": "^10.2.13",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
